{
  "name": "@pitvox/partner-react",
  "version": "0.7.5",
  "description": "React hooks and styled components for PitVox partner websites — leaderboards, competitions, driver dashboards",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "npm run build",
    "release": "release-it"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "release-it": "^19.2.4",
    "vite": "^6.0.0"
  },
  "keywords": [
    "pitvox",
    "simracing",
    "leaderboards",
    "competitions",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "homepage": "https://github.com/meekysoft/pitvox-partner-react#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/meekysoft/pitvox-partner-react.git"
  }
}
